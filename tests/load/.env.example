# tests/load/ 用 環境変数テンプレート
# このファイルをコピーして tests/load/.env を作成し、実値を埋めてから k6 を実行する。
# .env は .gitignore 済み。絶対にコミットしないこと。

# ============================================================
# 対象環境 (AWS / Azure / GCP の URL を 1 つだけ指定)
# ============================================================
# AWS:   https://<dist>.cloudfront.net
# Azure: https://<endpoint>.azurefd.net
# GCP:   https://<lb-domain-or-ip>
BASE_URL=https://example.cloudfront.net

# ============================================================
# Auth0 (ROPG: Resource Owner Password Grant)
# ============================================================
# 事前に Auth0 ダッシュボードで以下を準備しておくこと:
#   1. Application: Regular Web App (または Native) で 1 つ作成
#      - Settings → Advanced Settings → Grant Types → "Password" を ON
#   2. Tenant Settings → General → "Default Directory" にデータベース接続名 (例: Username-Password-Authentication) を設定
#   3. ロードテスト専用のテストユーザーを Database 接続に 1 つ作成
AUTH0_DOMAIN=your-tenant.auth0.com
AUTH0_AUDIENCE=https://api.example.com
AUTH0_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxx
AUTH0_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx
AUTH0_USERNAME=loadtest@example.com
AUTH0_PASSWORD=changeme
# ROPG で要求するスコープ (空でも可)
AUTH0_SCOPE=openid profile email
